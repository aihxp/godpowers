{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://godpowers.dev/schema/extension-manifest.v1.json",
  "title": "Godpowers Extension Manifest (v1)",
  "description": "Declares an installable godpowers skill-pack.",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "engines", "provides"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "enum": ["godpowers/v1"]
    },
    "kind": {
      "type": "string",
      "enum": ["Extension"]
    },
    "metadata": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^@[a-z0-9-]+/[a-z0-9-]+$",
          "description": "Scoped npm package name, e.g. '@godpowers/security-pack'"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "description": {
          "type": "string"
        },
        "homepage": { "type": "string", "format": "uri" },
        "license": { "type": "string" }
      }
    },
    "engines": {
      "type": "object",
      "required": ["godpowers"],
      "properties": {
        "godpowers": {
          "type": "string",
          "description": "SemVer range for required godpowers version (e.g. '>=0.13.0 <2.0.0')"
        }
      }
    },
    "provides": {
      "type": "object",
      "description": "What this extension contributes to the godpowers surface.",
      "properties": {
        "agents": { "type": "array", "items": { "type": "string" } },
        "skills": { "type": "array", "items": { "type": "string" } },
        "workflows": { "type": "array", "items": { "type": "string" } },
        "have-nots": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["prefix"],
            "properties": {
              "prefix": { "type": "string", "pattern": "^[A-Z][A-Z0-9]*$" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "activation": {
      "type": "object",
      "description": "When the extension loads. Lazy by default.",
      "properties": {
        "on": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "skill": { "type": "string" },
              "extension-list-query": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
