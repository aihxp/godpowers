{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://godpowers.dev/schema/state.v1.json",
  "title": "Godpowers Project State (v1)",
  "description": "Machine-managed project state. The 'facts' artifact in the three load-bearing artifacts pattern.",
  "type": "object",
  "required": ["$schema", "version", "project", "tiers"],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://godpowers.dev/schema/state.v1.json"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "project": {
      "type": "object",
      "required": ["name", "started"],
      "properties": {
        "name": { "type": "string" },
        "started": { "type": "string", "format": "date-time" }
      }
    },
    "active-workstream": {
      "type": "string",
      "default": "main"
    },
    "tiers": {
      "type": "object",
      "patternProperties": {
        "^tier-[0-9]+$": {
          "type": "object",
          "patternProperties": {
            "^[a-z][a-z0-9-]*$": {
              "$ref": "#/$defs/SubStep"
            }
          }
        }
      }
    },
    "lifecycle-phase": {
      "type": "string",
      "enum": [
        "pre-init",
        "in-arc",
        "steady-state-active",
        "post-incident-pending",
        "in-migration",
        "spike-pending-followup"
      ]
    },
    "mode": {
      "type": "string",
      "enum": ["A", "B", "C", "E"],
      "description": "Mirror of intent.yaml mode for runtime queries. A=greenfield, B=brownfield/gap-fill, C=audit-only, E=bluefield."
    },
    "mode-d-suite": {
      "type": "boolean",
      "default": false,
      "description": "True when this repo is part of a multi-repo suite (god-coordinator owns suite scope)."
    },
    "mode-detected-from": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Signals used to detect the mode (e.g. 'no-package-json-found', 'org-context-yaml-in-parent')."
    },
    "mode-announced-as": {
      "type": "string",
      "description": "Human-friendly label shown to the user (greenfield/brownfield/bluefield/audit)."
    },
    "linkage": {
      "type": "object",
      "description": "Slot for linkage map summary. Authoritative file is .godpowers/linkage.json.",
      "additionalProperties": true
    },
    "yolo-decisions": {
      "type": "array",
      "description": "Auto-decisions made under --yolo. Mirrored to YOLO-DECISIONS.md.",
      "items": { "type": "object", "additionalProperties": true }
    }
  },
  "$defs": {
    "SubStep": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "in-flight", "done", "skipped", "imported", "failed", "re-invoked"]
        },
        "artifact": {
          "type": "string",
          "description": "Relative path from .godpowers/"
        },
        "artifact-hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "agent-version": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*@\\d+\\.\\d+\\.\\d+$"
        },
        "have-nots-passed": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z]+-\\d{2}$"
          }
        },
        "updated": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "string",
          "description": "Free-form for skip reason, failure detail, etc."
        }
      }
    }
  },
  "additionalProperties": false
}
