{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://godpowers.dev/schema/state.v1.json",
  "title": "Godpowers Project State (v1)",
  "description": "Machine-managed project state. The 'facts' artifact in the three load-bearing artifacts pattern.",
  "type": "object",
  "required": ["$schema", "version", "project", "tiers"],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://godpowers.dev/schema/state.v1.json"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "project": {
      "type": "object",
      "required": ["name", "started"],
      "properties": {
        "name": { "type": "string" },
        "started": { "type": "string", "format": "date-time" }
      }
    },
    "active-workstream": {
      "type": "string",
      "default": "main"
    },
    "tiers": {
      "type": "object",
      "patternProperties": {
        "^tier-[0-9]+$": {
          "type": "object",
          "patternProperties": {
            "^[a-z][a-z0-9-]*$": {
              "$ref": "#/$defs/SubStep"
            }
          }
        }
      }
    },
    "lifecycle-phase": {
      "type": "string",
      "enum": [
        "pre-init",
        "in-arc",
        "steady-state-active",
        "post-incident-pending",
        "in-migration",
        "spike-pending-followup"
      ]
    },
    "mode": {
      "type": "string",
      "enum": ["A", "B", "C", "E"],
      "description": "Mirror of intent.yaml mode for runtime queries. A=greenfield, B=brownfield/gap-fill, C=audit-only, E=bluefield."
    },
    "mode-d-suite": {
      "type": "boolean",
      "default": false,
      "description": "True when this repo is part of a multi-repo suite (god-coordinator owns suite scope)."
    },
    "mode-detected-from": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Signals used to detect the mode (e.g. 'no-package-json-found', 'org-context-yaml-in-parent')."
    },
    "mode-announced-as": {
      "type": "string",
      "description": "Human-friendly label shown to the user (greenfield/brownfield/bluefield/audit)."
    },
    "linkage": {
      "type": "object",
      "description": "Slot for linkage map summary. Authoritative file is .godpowers/linkage.json.",
      "additionalProperties": true
    },
    "source-systems": {
      "type": "array",
      "description": "Detected external planning systems imported into Godpowers and eligible for managed sync-back.",
      "items": {
        "type": "object",
        "required": ["id", "name", "confidence", "files", "import-hash"],
        "properties": {
          "id": {
            "type": "string",
            "enum": ["gsd", "bmad", "superpowers", "other"]
          },
          "name": { "type": "string" },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "markers": {
            "type": "array",
            "items": { "type": "string" }
          },
          "files": {
            "type": "array",
            "items": { "type": "string" }
          },
          "import-hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "imported-at": {
            "type": "string",
            "format": "date-time"
          },
          "sync-back-enabled": {
            "type": "boolean",
            "default": true
          },
          "last-sync-back-hash": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^sha256:[a-f0-9]{64}$"
              },
              { "type": "null" }
            ]
          },
          "last-sync-back-at": {
            "type": "string",
            "format": "date-time"
          },
          "conflict-count": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    },
    "godpowers-features": {
      "type": "object",
      "description": "Installed Godpowers feature awareness recorded for this project.",
      "required": ["feature-set-version", "runtime-version", "known"],
      "properties": {
        "feature-set-version": {
          "type": "integer",
          "minimum": 1
        },
        "runtime-version": {
          "type": "string",
          "pattern": "^(unknown|\\d+\\.\\d+\\.\\d+)$"
        },
        "known": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "last-awareness-refresh-at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "yolo-decisions": {
      "type": "array",
      "description": "Auto-decisions made under --yolo. Mirrored to YOLO-DECISIONS.md.",
      "items": { "type": "object", "additionalProperties": true }
    },
    "lock": {
      "type": "object",
      "description": "Cooperative advisory lock for multi-user / multi-agent concurrency. The orchestrator acquires a lock before mutating state, releases on completion or after a stale-lock timeout. Concurrent writers see the lock and pause or pick a different sub-step.",
      "properties": {
        "holder": {
          "type": "string",
          "description": "Identifier of the actor holding the lock (e.g. 'alice@laptop', 'god-orchestrator@run-abc123')."
        },
        "acquired": {
          "type": "string",
          "format": "date-time"
        },
        "expires": {
          "type": "string",
          "format": "date-time",
          "description": "Lock auto-expires after this time. Stale locks (past expires) are reclaimable by any actor with a warning event."
        },
        "scope": {
          "type": "string",
          "description": "What the holder is currently mutating (e.g. 'tier-1.arch', 'linkage', 'all'). Lets concurrent actors pick non-conflicting work."
        }
      }
    }
  },
  "$defs": {
    "SubStep": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "in-flight", "done", "skipped", "imported", "failed", "re-invoked"]
        },
        "artifact": {
          "type": "string",
          "description": "Relative path from .godpowers/"
        },
        "artifact-hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "agent-version": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*@\\d+\\.\\d+\\.\\d+$"
        },
        "have-nots-passed": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z]+-\\d{2}$"
          }
        },
        "updated": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "string",
          "description": "Free-form for skip reason, failure detail, etc."
        }
      }
    }
  },
  "additionalProperties": false
}
