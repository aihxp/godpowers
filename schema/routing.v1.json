{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://godpowers.dev/schema/routing.v1.json",
  "title": "Godpowers Command Routing (v1)",
  "description": "Defines prerequisites, execution, and routing for a single slash command.",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "execution", "endoff"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "enum": ["godpowers/v1"]
    },
    "kind": {
      "type": "string",
      "enum": ["CommandRouting"]
    },
    "metadata": {
      "type": "object",
      "required": ["command"],
      "properties": {
        "command": {
          "type": "string",
          "pattern": "^/god-[a-z-]+$"
        },
        "description": { "type": "string" },
        "tier": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        }
      }
    },
    "prerequisites": {
      "type": "object",
      "properties": {
        "required": {
          "type": "array",
          "items": { "$ref": "#/$defs/Prerequisite" }
        },
        "recommended": {
          "type": "array",
          "items": { "$ref": "#/$defs/Recommendation" }
        }
      }
    },
    "execution": {
      "type": "object",
      "required": ["spawns"],
      "properties": {
        "spawns": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Agent names this skill spawns (in order or parallel)"
        },
        "context": { "type": "string", "enum": ["fresh", "shared"], "default": "fresh" },
        "reads": {
          "type": "array",
          "items": { "type": "string" }
        },
        "writes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "secondary-spawns": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Agents spawned by primary agent (e.g., reviewers)"
        }
      }
    },
    "standards": {
      "type": "object",
      "description": "Arc-ready style discipline checks at this gate",
      "properties": {
        "substitution-test": { "type": "boolean", "default": false },
        "three-label-test": { "type": "boolean", "default": false },
        "have-nots": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Z]+-\\d{2}$" }
        },
        "gate-on-failure": {
          "type": "string",
          "enum": ["pause-for-user", "auto-fix", "warn", "block"],
          "default": "pause-for-user"
        }
      }
    },
    "success-path": {
      "type": "object",
      "properties": {
        "next-recommended": {
          "type": "string",
          "pattern": "^/god-[a-z-]+$"
        },
        "alternatives": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "command": { "type": "string" },
              "when": { "type": "string", "description": "Condition for this alternative" }
            }
          }
        }
      }
    },
    "failure-path": {
      "type": "object",
      "properties": {
        "on-have-nots-fail": { "type": "string", "description": "What to do if have-nots fail" },
        "on-pause": { "type": "string", "description": "What to do on legitimate pause" },
        "on-error": { "type": "string", "description": "What to do on unexpected error" }
      }
    },
    "endoff": {
      "type": "object",
      "required": ["state-update"],
      "properties": {
        "state-update": {
          "type": "string",
          "description": "What changes in state.json"
        },
        "events": {
          "type": "array",
          "items": { "type": "string" }
        },
        "lifecycle-transition": {
          "type": "string",
          "description": "If this command transitions lifecycle phase"
        }
      }
    }
  },
  "$defs": {
    "Prerequisite": {
      "type": "object",
      "required": ["check"],
      "properties": {
        "check": {
          "type": "string",
          "description": "Predicate: e.g., 'state:tier-1.prd.done', 'file:.godpowers/state.json'"
        },
        "auto-complete": {
          "type": "string",
          "pattern": "^/god-[a-z-]+$",
          "description": "Command to run if prerequisite missing"
        },
        "human-required": {
          "type": "boolean",
          "description": "If true, ask user before auto-completing"
        }
      }
    },
    "Recommendation": {
      "type": "object",
      "required": ["command"],
      "properties": {
        "command": { "type": "string", "pattern": "^/god-[a-z-]+$" },
        "when": { "type": "string", "description": "Condition for this recommendation" }
      }
    }
  }
}
