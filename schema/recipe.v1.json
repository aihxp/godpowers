{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://godpowers.dev/schema/recipe.v1.json",
  "title": "Godpowers Recipe (v1)",
  "description": "Scenario-based recipe that agents consult to map user intent to command sequences.",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "triggers", "sequences"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "enum": ["godpowers/v1"]
    },
    "kind": {
      "type": "string",
      "enum": ["Recipe"]
    },
    "metadata": {
      "type": "object",
      "required": ["name", "category"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "category": {
          "type": "string",
          "enum": [
            "starting", "planning", "building", "shipping",
            "production", "maintaining", "recovering", "collaborating",
            "knowledge", "feature-addition", "configuration", "meta"
          ]
        },
        "description": { "type": "string" }
      }
    },
    "triggers": {
      "type": "object",
      "properties": {
        "intent-keywords": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Keywords/phrases that match user intent"
        },
        "state-conditions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "State predicates: lifecycle-phase == X, tier-N.sub.status == Y"
        },
        "anti-conditions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Conditions where this recipe does NOT apply"
        }
      }
    },
    "decision-tree": {
      "type": "array",
      "description": "Optional decision tree for branching based on user answers",
      "items": {
        "type": "object",
        "required": ["question", "options"],
        "properties": {
          "question": { "type": "string" },
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["answer"],
              "properties": {
                "answer": { "type": "string" },
                "scope": { "type": "string" },
                "sequence-name": { "type": "string" },
                "sequence": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/Step" }
                }
              }
            }
          }
        }
      }
    },
    "sequences": {
      "type": "object",
      "description": "Named command sequences that this recipe can execute",
      "patternProperties": {
        "^[a-z][a-z0-9-]*$": {
          "type": "object",
          "required": ["steps"],
          "properties": {
            "description": { "type": "string" },
            "steps": {
              "type": "array",
              "items": { "$ref": "#/$defs/Step" }
            }
          }
        }
      }
    },
    "default-sequence": {
      "type": "string",
      "description": "Which sequence to use if no decision-tree branching"
    }
  },
  "$defs": {
    "Step": {
      "type": "object",
      "required": ["command"],
      "properties": {
        "command": {
          "type": "string",
          "pattern": "^/god-[a-z-]+(\\s.*)?$"
        },
        "why": { "type": "string", "description": "Why this step in this sequence" },
        "wait-for": { "type": "string", "enum": ["completion", "user-confirm"], "default": "completion" },
        "skip-when": { "type": "string", "description": "Condition to skip this step" }
      }
    }
  }
}
