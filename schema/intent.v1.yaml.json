{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://godpowers.dev/schema/intent.v1.yaml.json",
  "title": "Godpowers Project Intent (v1)",
  "description": "Hand-edited project configuration. The 'intent' artifact in the three load-bearing artifacts pattern.",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "mode", "scale"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "enum": ["godpowers/v1"],
      "description": "Schema version. Frozen at v1.0; v2 would be breaking."
    },
    "kind": {
      "type": "string",
      "enum": ["Project"]
    },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "started": { "type": "string", "format": "date-time" }
      }
    },
    "mode": {
      "type": "string",
      "enum": ["A", "B", "C"],
      "description": "A=greenfield, B=gap-fill, C=audit-only. (Mode D multi-repo is post-1.0.)"
    },
    "scale": {
      "type": "string",
      "enum": ["trivial", "small", "medium", "large", "enterprise"],
      "description": "Drives which tiers and personas activate."
    },
    "extensions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^@[a-z0-9-]+/[a-z0-9-]+@[\\^~]?\\d+\\.\\d+\\.\\d+$",
        "description": "npm package with SemVer constraint, e.g. '@godpowers/security-pack@^1.0.0'"
      }
    },
    "workflow": {
      "type": "string",
      "default": "full-arc",
      "description": "Name of the workflow YAML file to use."
    },
    "executors": {
      "type": "object",
      "properties": {
        "default": {
          "type": "string",
          "enum": ["claude-code", "codex", "cursor", "windsurf", "opencode", "gemini", "copilot", "augment", "trae", "cline", "kilo", "antigravity", "qwen", "codebuddy", "pi"]
        },
        "fallback": {
          "type": "string",
          "enum": ["claude-code", "codex", "cursor", "windsurf", "opencode", "gemini", "copilot", "augment", "trae", "cline", "kilo", "antigravity", "qwen", "codebuddy", "pi"]
        }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "yolo": { "type": "boolean", "default": false },
        "conservative": { "type": "boolean", "default": false },
        "trash-retention-days": { "type": "integer", "minimum": 0, "default": 30 }
      }
    }
  },
  "additionalProperties": false
}
